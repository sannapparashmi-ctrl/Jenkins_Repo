<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RegressionSuite" parallel="false" thread-count="2">
	<listeners>
		<listener class-name="com.qa.usermanagement.listeners.Transformer" />
		<listener class-name="com.qa.usermanagement.listeners.AllureListeners" />
		<listener class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
	</listeners>
	<test name="Chrome">
		<parameter name="browserName" value="${browser}"></parameter>
		<parameter name="browserHeadless" value="${headless}"></parameter>
		<parameter name="browserPrivate" value="${private}"></parameter>
		<classes>
			<class name="com.qa.usermanagement.tests.LoginTest" />
			<class name="com.qa.usermanagement.tests.RegisterationTest" />
		</classes>
	</test> <!--
	Test -->
	<test name="Firefox">
		<parameter name="browserName" value="${browser}"></parameter>
		<parameter name="browserHeadless" value="${headless}"></parameter>
		<parameter name="browserPrivate" value="${private}"></parameter>
		<classes>
			<class name="com.qa.usermanagement.tests.LoginTest" />
			<class name="com.qa.usermanagement.tests.RegisterationTest" />
		</classes>
	</test> <!--
	Test -->
</suite> <!--
Suite -->
